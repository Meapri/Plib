{
  "name": "plib-gimp-demo-profile",
  "version": "v104",
  "target_app": "gimp",
  "bundle_lock": "/usr/share/androlinux/gimp-demo-bundle.lock.json",
  "program": "/usr/bin/gimp",
  "argv": ["gimp", "--new-instance", "--no-data", "--no-fonts"],
  "env": {
    "GDK_BACKEND": "wayland",
    "WAYLAND_DISPLAY": "alr-gimp-0",
    "XDG_RUNTIME_DIR": "/tmp",
    "NO_AT_BRIDGE": "1"
  },
  "presentation": "Android Surface via Plib native Wayland/AHardwareBuffer bridge path",
  "status": "gimp3-wayland-materialized-version-and-display-probe-ready"
}
